{
  "name": "ofluence-website",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Marketing website for Ofluence",
  "author": {
    "name": "Ofluence Pvt. Ltd.",
    "email": "support@ofluence.ai"
  },
  "license": "UNLICENSED",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/compress-output.mjs",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "doctor": "react-doctor",
    "preview": "vite preview",
    "format": "prettier --write '**/*.{ts,tsx,js,jsx,css,html}'",
    "format:check": "prettier --check '**/*.{ts,tsx,js,jsx,css,html}'",
    "prepare": "husky",
    "commit": "cz"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/sora": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.1.1",
    "@hugeicons/react": "^1.1.6",
    "@posthog/react": "^1.9.0",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-start": "^1.167.42",
    "immer": "^11.1.4",
    "motion": "^12.38.0",
    "posthog-js": "^1.369.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sonner": "^2.0.7",
    "web-vitals": "^5.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@commitlint/cz-commitlint": "^20.5.1",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/eslint-plugin-router": "^1.161.6",
    "@tanstack/react-router-devtools": "^1.166.13",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commitizen": "^4.3.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nitro": "^3.0.260415-beta",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "react-doctor": "^0.0.37",
    "shadcn": "^4.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.9",
    "vite-plugin-svgr": "^5.2.0"
  },
  "pnpm": {
    "overrides": {
      "@typescript-eslint/utils": "^8.55.0"
    }
  },
  "config": {
    "commitizen": {
      "path": "@commitlint/cz-commitlint"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,js}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,md}": [
      "prettier --write"
    ]
  }
}
